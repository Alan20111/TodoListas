<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="400.0" prefWidth="300.0" spacing="15.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="dev.alan20111.todolist.controller.CategoryController">
    <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
    <Label text="Mis Categorías"><font><Font name="System Bold" size="18.0" /></font></Label>
    <HBox spacing="10.0">
        <TextField fx:id="txtNewCategory" promptText="Nueva categoría..." HBox.hgrow="ALWAYS" />
        <Button onAction="#handleAddCategory" style="-fx-background-color: #4CAF50; -fx-text-fill: white;" text="+" />
    </HBox>
    <ListView fx:id="listCategories" VBox.vgrow="ALWAYS" />
    <Button maxWidth="Infinity" onAction="#handleDeleteCategory" style="-fx-background-color: #f44336; -fx-text-fill: white;" text="Eliminar Seleccionada" />
</VBox>